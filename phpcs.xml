<?xml version="1.0"?>
<ruleset name="FacturX">
    <description>PSR-12 coding standard for facturx-php</description>

    <rule ref="PSR12" />

    <file>src</file>

    <!-- FPDI parent class uses underscore-prefixed methods that we must override -->
    <rule ref="PSR2.Methods.MethodDeclaration.Underscore">
        <exclude-pattern>src/Fpdi/PdfA3b.php</exclude-pattern>
    </rule>
</ruleset>
